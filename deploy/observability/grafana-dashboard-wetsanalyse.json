          "datasource": {
            "type": "prometheus",
            "uid": "wa-prometheus"
          },
          "editorMode": "code",
          "expr": "sum(wetsanalyse_llm_tokens_total)",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "LLM-tokens totaal",
