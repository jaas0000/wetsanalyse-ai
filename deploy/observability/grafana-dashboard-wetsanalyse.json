      "panels": [],
      "title": "Wetsanalyse-engine (API)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "wa-prometheus"
      },
      "description": "95e-percentiel duur van een orchestrator-fase, per stap.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "stacking": {
              "group": "A",
              "mode": "none"
            }
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "wa-prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, stap) (rate(wetsanalyse_fase_duur_ms_milliseconds_bucket{stap=~\"$stap\"}[$__rate_interval])))",
          "instant": false,
          "legendFormat": "{{stap}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Fase-duur p95 per stap",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "wa-prometheus"
      },
      "description": "Gemiddelde fase-duur (sum/count), per stap.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "stacking": {
              "group": "A",
              "mode": "none"
            }
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "wa-prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (stap)(rate(wetsanalyse_fase_duur_ms_milliseconds_sum{stap=~\"$stap\"}[$__rate_interval])) / sum by (stap)(rate(wetsanalyse_fase_duur_ms_milliseconds_count{stap=~\"$stap\"}[$__rate_interval]))",
          "instant": false,
          "legendFormat": "{{stap}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Fase-duur gemiddeld per stap",
      "type": "timeseries"
    },
    {
      "datasource": {
