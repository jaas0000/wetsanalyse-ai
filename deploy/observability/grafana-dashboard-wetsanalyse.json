          "datasource": {
            "type": "prometheus",
            "uid": "wa-prometheus"
          },
          "editorMode": "code",
          "expr": "sum(wettenbank_cache_toegang_total{resultaat=\"hit\"}) / clamp_min(sum(wettenbank_cache_toegang_total), 1)",
          "instant": true,
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Cache hit-ratio",
      "type": "stat"
