# Wetsanalyse — lokale configuratie
# Kopieer naar .env en vul in

# Azure AI Foundry endpoint (geen trailing slash)
LLM_API_BASE=https://JOUW-ENDPOINT.services.ai.azure.com

# Publieke URL van de frontend
# Lokaal:      http://localhost:3000
# Productie:   https://wetsanalyse.jouwdomein.nl
AUTH_URL=http://localhost:3000

# Azure AI Foundry API-key (wordt door gen-secrets.py uitgelezen)
LLM_API_KEY=

# Optioneel — standaard is claude-sonnet-4-6
# LLM_MODEL=claude-sonnet-4-6
