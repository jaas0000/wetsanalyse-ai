# Gecombineerde backend-image: PostgreSQL 16 + FastAPI in één container.
# Supervisord beheert beide processen; een entrypoint-script initialiseert
# de database eenmalig bij de eerste start.
#
# Bouwen vanuit de projectroot (nodig voor api/ en .claude/skills/):
#   docker build -f deploy/compose/Dockerfile.backend -t wetsanalyse-backend .
#   podman build -f deploy/compose/Dockerfile.backend -t wetsanalyse-backend .

FROM python:3.12-slim

# ── PostgreSQL 16 via de officiële PGDG-repo ──────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
        curl gnupg \
    && curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc \
       | gpg --dearmor -o /usr/share/keyrings/postgresql.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/postgresql.gpg] \
       https://apt.postgresql.org/pub/repos/apt bookworm-pgdg main" \
       > /etc/apt/sources.list.d/pgdg.list \
    && apt-get update && apt-get install -y --no-install-recommends \
        postgresql-16 \
        supervisor \
        gosu \
    && rm -rf /var/lib/apt/lists/*

# ── Python-dependencies (via uv, zelfde patroon als api/Dockerfile) ───────────
COPY --from=ghcr.io/astral-sh/uv:0.11 /uv /bin/uv

WORKDIR /app/api

ENV UV_PYTHON_PREFERENCE=only-system

COPY api/pyproject.toml api/uv.lock /app/api/
RUN uv sync --extra llm --frozen

# ── Applicatiecode + skill-references ─────────────────────────────────────────
COPY api /app/api
COPY .claude/skills/wetsanalyse /app/.claude/skills/wetsanalyse
COPY .claude/skills/regelspraak  /app/.claude/skills/regelspraak

# ── Process-management en init-scripts ────────────────────────────────────────
COPY deploy/compose/supervisord.conf      /etc/supervisor/conf.d/wetsanalyse.conf
COPY deploy/compose/backend-entrypoint.sh /usr/local/bin/backend-entrypoint.sh
RUN chmod +x /usr/local/bin/backend-entrypoint.sh

ENV PATH="/app/api/.venv/bin:$PATH"
ENV HOME=/tmp

# PostgreSQL data-map (mount als volume voor persistentie).
VOLUME ["/var/lib/postgresql/data"]

EXPOSE 3000

ENTRYPOINT ["/usr/local/bin/backend-entrypoint.sh"]
