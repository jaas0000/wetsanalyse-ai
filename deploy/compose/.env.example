# Kopieer dit bestand naar .env en vul de drie verplichte waarden in.
# De rest wordt automatisch gegenereerd door gen-secrets.py.

# ── Verplicht in te vullen ────────────────────────────────────────────────────

# Azure AI Foundry API-key
LLM_API_KEY=<jouw-azure-ai-foundry-key>

# Azure AI Foundry endpoint (zonder /models achteraan)
LLM_API_BASE=https://<resource>.services.ai.azure.com

# Publieke URL van de webapp — verplicht voor Auth.js login/logout-redirects.
# Lokaal:      http://localhost:3000
# Productie:   https://wetsanalyse.jouwdomein.nl
AUTH_URL=https://wetsanalyse.jouwdomein.nl

# ── Optioneel aanpassen ───────────────────────────────────────────────────────

# LLM-model (default is claude-sonnet-4-6)
LLM_MODEL=claude-sonnet-4-6
