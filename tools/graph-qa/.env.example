# GraphDB MCP
GRAPHDB_MCP_URL=https://graphdb-mcp.ipalm.nl/mcp
GRAPHDB_TOKEN=<jouw-graphdb-token>

# Azure AI Foundry (Anthropic)
AZURE_FOUNDRY_API_KEY=<jouw-azure-foundry-key>
AZURE_FOUNDRY_BASE_URL=https://<jouw-resource>.services.ai.azure.com/anthropic
LLM_MODEL=claude-sonnet-4-6

# API-beveiliging (laat leeg om open te draaien, bijv. lokaal)
QA_API_TOKEN=<kies-een-sterk-token>

# CORS: kommagescheiden lijst van toegestane origins
# Gebruik * voor volledig open (alleen voor lokale dev)
CORS_ORIGINS=https://jouw-website.nl

# Luisterpoort (default: 8080)
PORT=8080
