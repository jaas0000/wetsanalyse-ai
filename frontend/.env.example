# Waar de BFF (Next.js server) de Wetsanalyse-API server-side bereikt.
# Productie: het interne container-adres binnen het proxy-netwerk.
API_BASE_URL=http://wetsanalyse-api:3000
# Lokaal dev tegen de publieke API kan ook:
# API_BASE_URL=https://wetsanalyse-api.ipalm.nl
# Lokaal dev tegen een lokaal draaiende API:
# API_BASE_URL=http://localhost:3000

# Bearer-token voor de API (server-side; komt NOOIT in de browser).
# Dit is ALLEEN de tokenwaarde (het deel NA de ":") uit de API-tokenlijst.
# Staat in de API bv. "frontend:dev-token-123", dan hoort hier "dev-token-123".
API_TOKEN=dev-token-123

# Productie i.p.v. API_TOKEN: pad naar een secret-bestand (heeft voorrang).
# API_TOKEN_FILE=/run/secrets/frontend_api_token

# Apart admin-bearer-token voor het beheerscherm (/beheer → /v1/admin/*). Alleen de tokenwaarde
# (deel NA de ":") uit de admin-tokenlijst van de API (WETSANALYSE_ADMIN_TOKENS).
ADMIN_API_TOKEN=dev-admin-token-123
# Productie: pad naar een secret-bestand (heeft voorrang).
# ADMIN_API_TOKEN_FILE=/run/secrets/frontend_admin_token

# Auth.js (login-module): geheim om de sessie-cookie/JWT te ondertekenen. Genereer er één met
# `openssl rand -base64 32` (of `npx auth secret`). Verplicht zodra de login actief is.
AUTH_SECRET=genereer-met-openssl-rand-base64-32
# Achter een reverse proxy VERPLICHT: de publieke origin voor Auth.js-redirects. Zonder dit
# springt in-/uitloggen naar het interne 0.0.0.0:3000. Lokaal (direct op localhost) niet nodig.
# AUTH_URL=https://wetsanalyse.example.nl

# De kennisgraaf-chatbot (zwevende chatbel) wordt via het /beheer-scherm geconfigureerd
# (webhook-URL, secret en aan/uit) en opgeslagen in de API-settings — geen env-var nodig.

NODE_ENV=development
