# Voorbeeld-omgeving voor lokaal draaien (kopieer naar .env en vul in; .env niet committen).
# In productie: gebruik de *_FILE-varianten (Docker secrets), niet plain env.

# --- Auth: per-client bearer-tokens "id:token,id2:token2" ---
# Leeg laten + WETSANALYSE_AUTH_REQUIRED=0 om auth lokaal uit te zetten.
WETSANALYSE_API_TOKENS=lokaal:dev-token-123
WETSANALYSE_AUTH_REQUIRED=1

# --- Admin-auth: aparte tokens voor /v1/admin/* (LLM-modelprofielen beheren) ---
# Zelfde "id:token,..."-vorm. Altijd auth-plichtig (geen AUTH_REQUIRED-bypass); leeg = alles 401.
WETSANALYSE_ADMIN_TOKENS=admin:dev-admin-token-123
# Productie: WETSANALYSE_ADMIN_TOKENS_FILE=secrets/admin_tokens

# --- Database (PostgreSQL via SQLAlchemy async; asyncpg-driver) ---
# Vorm: postgresql+asyncpg://user:pass@host:5432/db. Lokaal bv. een docker-postgres:
#   docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=wetsanalyse -e POSTGRES_USER=wetsanalyse \
#     -e POSTGRES_DB=wetsanalyse postgres:16
DATABASE_URL=postgresql+asyncpg://wetsanalyse:wetsanalyse@localhost:5432/wetsanalyse
# Productie: DATABASE_URL_FILE=secrets/database_url (CloudNativePG levert deze secret aan).

# --- Wettenbank-MCP ---
# Lokaal de publieke URL; in de stack intern: http://wettenbank-mcp:3000/mcp
WETTENBANK_MCP_URL=https://wettenbank-mcp.ipalm.nl/mcp
WETTENBANK_TOKEN=

# --- LLM-adapter (Azure eerst) ---
# Endpointtype bepaalt de provider-prefix (Fase 0 stelt dit vast):
#   azure_ai  → Azure AI Foundry / Models-as-a-Service (Claude/Sonnet)
#   azure     → Azure OpenAI (dan ook LLM_API_VERSION zetten)
LLM_PROVIDER=azure_ai
LLM_MODEL=
LLM_API_BASE=
LLM_API_KEY=
# Alleen voor azure (OpenAI):
# LLM_API_VERSION=2024-10-21
LLM_OUTPUT_STRATEGY=prompt_and_parse
LLM_TEMPERATURE=0
# Harde wandklok-timeout per LLM-call in seconden (0 = uit; provider-default blijft staan).
# WETSANALYSE_LLM_TIMEOUT_S=120

# Deze LLM_*-waarden seeden bij de EERSTE start één default-modelprofiel; daarna leven de
# profielen in de database (beheerbaar via /v1/admin/profiles of het /beheer-scherm).
# LLM_DEFAULT_PROFILE=azure-sonnet

# Master key (Fernet) voor versleuteling-at-rest van API-keys die via de admin-UI worden
# opgeslagen. Genereer met:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Ontbreekt deze, dan kun je géén API-key via de UI opslaan (profielen vallen terug op LLM_API_KEY).
LLM_CONFIG_SECRET=
# Productie: LLM_CONFIG_SECRET_FILE=secrets/llm_config_secret

# --- Engine ---
WETSANALYSE_MAX_RONDES=6
WETSANALYSE_MAX_AUTOCORRECTIE=1
# WETSANALYSE_ANALYSES_DIR=../analyses

# --- CORS ---
# Komma-gescheiden lijst van toegestane browser-origins. LEEG (default) = geen cross-origin
# browser-toegang; de BFF/clients praten server→server en hebben dit niet nodig. Zet dit alleen
# als een browser-origin de API rechtstreeks moet aanroepen, bijv.:
# CORS_ORIGINS=https://wetsanalyse.ipalm.nl

# --- Misbruik-/kostenbeheersing (0 = uit) ---
# WETSANALYSE_RATE_LIMIT_MAX=30
# WETSANALYSE_RATE_LIMIT_WINDOW=60
# Krappe limiet op POST /v1/admin/profiles/{name}/test (doet een betaalde LLM-call):
# WETSANALYSE_ADMIN_TEST_RATE_MAX=10
# WETSANALYSE_ADMIN_TEST_RATE_WINDOW=60
